---
// src/components/DiscordWidget.astro
---

<div class="discord-cta">
  <div class="discord-content">
    <h3>Willkommen im Little Haven! 🍼✨</h3>
    <p>
      Ein sicherer, strikt SFW-moderierter Ort für Ageregression, System-Austausch und Caregiver. 
      Finde Gleichgesinnte, tausche dich in unseren Themenkanälen aus oder nimm an gemeinsamen Spiele-Abenden teil.
      Wir freuen uns auf dich!
    </p>
    <a href="https://disboard.org/de/server/1270678011594670121" target="_blank" rel="noopener noreferrer" class="discord-button">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 127.14 96.36" fill="currentColor">
        <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1,105.25,105.25,0,0,0,32.19-16.14c2.64-27.38-4.51-51.11-19.32-72.15ZM42.68,65.36c-5.28,0-9.66-4.92-9.66-10.94s4.29-10.94,9.66-10.94,9.75,4.92,9.66,10.94C52.34,60.44,48.05,65.36,42.68,65.36Zm41.78,0c-5.28,0-9.66-4.92-9.66-10.94s4.29-10.94,9.66-10.94,9.75,4.92,9.66,10.94C94.13,60.44,89.84,65.36,84.46,65.36Z"/>
      </svg>
      Auf Disboard ansehen & Beitreten
    </a>
  </div>
</div>

<style>
  .discord-cta {
    background-color: var(--sl-color-bg-nav, #1e1e2e);
    border: 1px solid var(--sl-color-hairline, #333);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .discord-content h3 {
    margin-top: 0;
    color: var(--sl-color-white);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .discord-content p {
    color: var(--sl-color-gray-3, #ccc);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .discord-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background-color: #5865F2; /* Discord Blurple */
    color: white !important;
    text-decoration: none !important;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    transition: background-color 0.2s ease, transform 0.1s ease;
    width: fit-content;
  }

  .discord-button:hover {
    background-color: #4752C4;
    transform: translateY(-1px);
  }

  .discord-button svg {
    flex-shrink: 0;
  }
</style>
